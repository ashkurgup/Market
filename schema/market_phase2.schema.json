{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Market Phase 2 Schema",
  "description": "Phase-2 captures higher-timeframe context and detected intraday structural events. Detection only. No interpretation or execution logic.",

  "type": "object",
  "required": [
    "phase",
    "symbol",
    "session",
    "weekly_levels",
    "key_levels",
    "session_levels",
    "structure_events",
    "momentum_events",
    "global_indices",
    "bias",
    "computed_at"
  ],

  "properties": {
    "phase": {
      "type": "integer",
      "const": 2,
      "description": "Phase identifier (always 2)"
    },

    "symbol": {
      "type": "string",
      "description": "Market symbol (e.g., NIFTY)"
    },

    "session": {
      "type": "object",
      "required": ["start", "end", "timezone"],
      "properties": {
        "start": { "type": "string" },
        "end": { "type": "string" },
        "timezone": { "type": "string" }
      },
      "additionalProperties": false
    },

    "weekly_levels": {
      "type": "object",
      "required": [
        "previous_week_high",
        "previous_week_low",
        "week_start",
        "week_end"
      ],
      "properties": {
        "previous_week_high": { "type": ["number", "null"] },
        "previous_week_low": { "type": ["number", "null"] },
        "week_start": { "type": ["string", "null"], "format": "date" },
        "week_end": { "type": ["string", "null"], "format": "date" }
      },
      "additionalProperties": false
    },

    "key_levels": {
      "type": "object",
      "required": ["nearest_resistance", "nearest_support"],
      "properties": {
        "nearest_resistance": { "type": ["number", "null"] },
        "nearest_support": { "type": ["number", "null"] }
      },
      "additionalProperties": false
    },

    "session_levels": {
      "type": "object",
      "required": [
        "high",
        "low",
        "based_on_timeframe",
        "update_rule"
      ],
      "properties": {
        "high": { "type": ["number", "null"] },
        "low": { "type": ["number", "null"] },
        "based_on_timeframe": {
          "type": "string",
          "enum": ["15m"]
        },
        "update_rule": {
          "type": "string",
          "enum": ["on_candle_close"]
        }
      },
      "additionalProperties": false
    },

    "structure_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "direction", "price", "time", "timeframe"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["BOS", "CHOCH"]
          },
          "direction": {
            "type": "string",
            "enum": ["up", "down"]
          },
          "price": { "type": "number" },
          "time": { "type": "string", "format": "date-time" },
          "timeframe": {
            "type": "string",
            "enum": ["5m"]
          }
        },
        "additionalProperties": false
      }
    },

    "momentum_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "direction",
          "time",
          "timeframe",
          "relative_strength",
          "volume_relative"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["STRONG_CANDLE", "HIGH_VOLUME_BREAKOUT"]
          },
          "direction": {
            "type": "string",
            "enum": ["bullish", "bearish"]
          },
          "time": { "type": "string", "format": "date-time" },
          "timeframe": {
            "type": "string",
            "enum": ["5m"]
          },
          "relative_strength": {
            "type": "string",
            "enum": ["above_average"]
          },
          "volume_relative": {
            "type": "string",
            "enum": ["above_average"]
          }
        },
        "additionalProperties": false
      }
    },

    "global_indices": {
      "type": "object",
      "required": ["time_window_minutes", "indices"],
      "properties": {
        "time_window_minutes": { "type": "integer" },
        "indices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "percent_change"],
            "properties": {
              "name": { "type": "string" },
              "percent_change": { "type": ["number", "null"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },

    "bias": {
      "type": "object",
      "required": ["day", "h4", "h1"],
      "properties": {
        "day": { "type": ["string", "null"], "enum": ["bullish", "neutral", "bearish", null] },
        "h4": { "type": ["string", "null"], "enum": ["bullish", "neutral", "bearish", null] },
        "h1": { "type": ["string", "null"], "enum": ["bullish", "neutral", "bearish", null] }
      },
      "additionalProperties": false
    },

    "computed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },

  "additionalProperties": false
}
